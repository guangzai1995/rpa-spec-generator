# LLM 配置 - 结构化文本提取（minimax）
LLM_API_KEY=95e49ceafa1532608196ae9d8ccdb0654c41d2e4
LLM_BASE_URL=https://aicp.teamshub.com/openai/api/v1/openai/v1
